				"cells": [
					{
						"cell_type": "code",
						"metadata": {
							"collapsed": false
						},
						"source": [
							"from pyspark.sql.functions import col, to_date,lower\n",
							"\n",
							"df_bronze=spark.read.parquet(\"abfss://retailproject@retial1.dfs.core.windows.net/bronze/manish040596/azure-data-engineer-projects/refs/heads/main/retail_transactions_bronze.parquet\")\n",
							"display(df_bronze.limit(10))"
						],
						"outputs": [],
						"execution_count": 1
					},
					{
						"cell_type": "code",
						"metadata": {
							"collapsed": false
						},
						"source": [
							"df_silver = (\n",
							"    df_bronze.filter(col(\"event_type\").isin(\"purchase\"))\n",
							"    .dropna(subset=[\"customer_id\",\"amount\"])\n",
							"    .withColumn(\"event_date\",to_date(col(\"event_timestamp\")))\n",
							"    .withColumn(\"payment_method\",lower(col(\"payment_method\")))\n",
							"    .withColumn(\"amount\",col(\"amount\").cast(\"float\"))\n",
							"    .select(\n",
							"        \"event_id\",\"customer_id\",\"event_date\",\"product_id\",\"product_category\",\"payment_method\",\"amount\",\"location\"\n",
							"    )\n",
							")\n",
							"\n",
							"\n",
							"df_silver.write.mode(\"overwrite\").parquet(\"abfss://retailproject@retial1.dfs.core.windows.net/silver/\")\n",
							"display(df_silver.limit(5))\n",
							""
						],
						"outputs": [],
						"execution_count": 2
					},
					{
						"cell_type": "code",
						"metadata": {
							"collapsed": false
						},
						"source": [
							"# gold layer aggregate\n",
							"from pyspark.sql.functions import sum, count, col\n",
							"\n",
							"df_silver = spark.read.parquet(\n",
							"    'abfss://retailproject@retial1.dfs.core.windows.net/silver/'\n",
							")\n",
							"\n",
							"# Revenue aggregation\n",
							"df_revenue = (\n",
							"    df_silver\n",
							"    .groupBy('event_date')\n",
							"    .agg(\n",
							"        sum(\"amount\").alias(\"daily_revenue\"),\n",
							"        count(\"*\").alias(\"total_purchases\")\n",
							"    )\n",
							")\n",
							"\n",
							"# Top categories\n",
							"df_top_categories = (\n",
							"    df_silver\n",
							"    .groupBy('product_category')\n",
							"    .agg(sum(\"amount\").alias(\"total_sales\"))\n",
							"    .orderBy(col(\"total_sales\").desc())\n",
							")\n",
							"\n",
							"# Write outputs (separate folders)\n",
							"df_revenue.write.mode(\"overwrite\").parquet(\n",
							"    \"abfss://retailproject@retial1.dfs.core.windows.net/gold/revenue/\"\n",
							")\n",
							"\n",
							"df_top_categories.write.mode(\"overwrite\").parquet(\n",
							"    \"abfss://retailproject@retial1.dfs.core.windows.net/gold/top_categories/\"\n",
							")\n",
							"\n",
							"display(df_revenue.limit(10))\n",
							"display(df_top_categories.limit(10))\n",
							""
						],
						"outputs": [],
						"execution_count": 3
					}
				]
			},
